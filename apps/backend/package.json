{
  "name": "@sub-vocab/backend",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "description": "description",
  "scripts": {
    "build": "tsc && node esbuild.config.js",
    "dev": "tsx watch --trace-deprecation --env-file=.env server",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --fix",
    "start": "node --env-file=.env app.js",
    "vercel-build": "node --run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/http-proxy": "^11.4.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@sub-vocab/utils": "workspace:*",
    "fastify": "^5.7.4",
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@vercel/node": "^5.6.6",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0"
  }
}
